{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build - Compile TypeScript",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "isBackground": false
    },
    {
      "label": "Dev - Run Spec Tester (CLI)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "--", "sample-api.json"],
      "group": {
        "kind": "build"
      },
      "isBackground": false,
      "dependsOn": ["Build - Compile TypeScript"]
    },
    {
      "label": "Dev - Run Web Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev:web"],
      "group": {
        "kind": "build"
      },
      "isBackground": true,
      "dependsOn": ["Build - Compile TypeScript"],
      "problemMatcher": []
    },
    {
      "label": "Lint - Check Code",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "group": {
        "kind": "test"
      },
      "problemMatcher": ["$eslint - stylish"]
    }
  ]
}
